# =============================================================
# PLANTILLA de variables de entorno (este archivo SÍ va al repo)
# Uso: copia este archivo como ".env.local" y rellena los valores.
# .env.local está en .gitignore y nunca se sube.
# =============================================================

# --- Supabase (Depto 4) — se rellenará al crear el proyecto ---
# El prefijo NEXT_PUBLIC_ hace la variable visible en el NAVEGADOR.
# Por eso aquí solo van la URL y la anon key (pública, protegida por RLS).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Resend (Depto 5) — secreto absoluto ---
# SIN prefijo NEXT_PUBLIC_: solo existe en el servidor (serverless functions).
RESEND_API_KEY=
